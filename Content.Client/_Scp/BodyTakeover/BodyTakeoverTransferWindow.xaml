<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client._Scp.BodyTakeover.BodyTakeoverTransferWindow"
               Title="{Loc body-takeover-transfer-window-title}">
    <BoxContainer Orientation="Vertical">
        <Label Name="BodyLabel" />
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="TransferNowButton" />
            <Control MinSize="20 0" />
            <Button Name="WaitButton" />
            <Control MinSize="20 0" />
            <Button Name="DeclineButton" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
