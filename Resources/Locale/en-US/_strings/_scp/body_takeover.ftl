body-takeover-poll-window-title = Entity Available
body-takeover-poll-window-body = OOC: { $entity } needs a player. Would you like to take control?
body-takeover-poll-window-accept = Yes
body-takeover-poll-window-decline = No

body-takeover-transfer-window-title = Entity Assignment
body-takeover-transfer-window-body = OOC: You have been selected to play as { $entity }. You have { $delay } before automatic transfer.
body-takeover-transfer-window-now = Transfer now
body-takeover-transfer-window-wait = Wait
body-takeover-transfer-window-decline = Decline

body-takeover-delay-minutes = { $count ->
    [one] { $count } minute
    *[other] { $count } minutes
}
body-takeover-delay-seconds = { $count ->
    [one] { $count } second
    *[other] { $count } seconds
}
