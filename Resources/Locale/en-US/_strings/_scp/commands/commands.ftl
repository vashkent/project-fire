flicking-start-all-command = {$successful} out of {$all} possible lights are now flickering

cmd-vigers-desc = Toggles autokick and autodeadmin for users from the vigers list.
cmd-vigers-help = Usage: {$command} <autokick|autodeadmin> [true|false]
vigers-command-status = autokick: {$autokick}, autodeadmin: {$autodeadmin}
vigers-command-state-enabled = enabled
vigers-command-state-disabled = disabled
vigers-command-mode-unknown = Unknown mode "{$mode}". Use autokick or autodeadmin.
vigers-command-autokick-enabled = Autokick for users from the vigers list has been enabled.
vigers-command-autokick-disabled = Autokick for users from the vigers list has been disabled.
vigers-command-autodeadmin-enabled = Autodeadmin for users from the vigers list has been enabled.
vigers-command-autodeadmin-disabled = Autodeadmin for users from the vigers list has been disabled.
vigers-command-protected = Users from the vigers list cannot toggle this command.
vigers-autokick-reason = Connection denied by server policy.
